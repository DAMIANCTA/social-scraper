# Variables compartidas del proyecto

# Cliente
VITE_API_BASE_URL=http://localhost:4000

# Servidor
PUERTO_SERVIDOR=4000
ORIGEN_CLIENTE=http://localhost:5173

# Playwright y sesion persistente
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_STORAGE_STATE_PATH=almacenamiento/sesion/estado-sesion.json
INSTAGRAM_URL_BASE=https://www.instagram.com/

# Evidencias y salidas
CAPTURAS_HABILITADAS=true
RUTA_CAPTURAS=almacenamiento/capturas
RUTA_EXPORTACIONES=almacenamiento/exportaciones
RUTA_HISTORIAL=almacenamiento/historial
