{
  "name": "bitacora-publicaciones-servidor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/servidor.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/servidor.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "sesion:generar": "tsx src/sesion/generarSesionManual.ts",
    "navegador:instalar": "playwright install chromium"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "playwright": "^1.49.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
